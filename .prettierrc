{
  "printWidth": 100,
  "semi": true,
  "trailingComma": "all",
  "singleQuote": true,
  "quoteProps": "consistent",

  "plugins": ["@ianvs/prettier-plugin-sort-imports"],

  "importOrder": [
    "<TYPES>",
    "<BUILTIN_MODULES>",
    "<THIRD_PARTY_MODULES>",
    "",
    "<TYPES>^@/(.*)",
    "^@/(.*)",
    "",
    "<TYPES>^[.][.]/",
    "^[.][.]/",
    "<TYPES>^[.]/",
    "^[.]/"
  ],
  "importOrderParserPlugins": ["typescript"],
  "importOrderCaseSensitive": false
}
