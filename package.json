{
  "name": "repo-watch",
  "version": "1.0.0",
  "description": "GitHub Release Notification API",
  "author": "kftlfd",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": "^22"
  },
  "scripts": {
    "dev": "tsx --watch src/main.ts",
    "dev:infra:up": "docker compose up -d postgres redis",
    "dev:infra:down": "docker compose down",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && cp -r src/db/migrations dist/db/",
    "start": "node dist/main.js",
    "db:gen": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:watch": "vitest watch --config vitest.unit.config.ts",
    "test:unit:coverage": "vitest run --config vitest.unit.config.ts --coverage",
    "test:int": "vitest run --config vitest.int.config.ts",
    "test:int:watch": "vitest watch --config vitest.int.config.ts",
    "test:int:coverage": "vitest run --config vitest.int.config.ts --coverage",
    "test:int:db:up": "docker compose -f docker-compose.test.yml up -d",
    "test:int:db:down": "docker compose -f docker-compose.test.yml down",
    "lint": "prettier -c . && tsc -b && eslint . --max-warnings 0",
    "fmt": "prettier -w ."
  },
  "dependencies": {
    "@fastify/formbody": "8.0.2",
    "@fastify/swagger": "9.7.0",
    "@scalar/fastify-api-reference": "1.52.2",
    "bullmq": "5.73.2",
    "dotenv": "17.4.1",
    "drizzle-orm": "0.45.2",
    "fastify": "5.8.4",
    "fastify-type-provider-zod": "6.1.0",
    "ioredis": "5.10.1",
    "neverthrow": "8.2.0",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "tsc-alias": "1.8.16",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@types/node": "22.19.17",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "4.1.4",
    "drizzle-kit": "0.31.10",
    "eslint": "10.2.0",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "vitest": "4.1.4"
  }
}
